  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function base64UrlEncodeUtf8(str) {",
          "    const bytes = unescape(encodeURIComponent(str));",
          "    let binary = '';",
          "    for (let i = 0; i < bytes.length; i++) {",
          "        binary += String.fromCharCode(bytes.charCodeAt(i));",
          "    }",
          "    const base64 = btoa(binary);",
          "    return base64.split('+').join('-').split('/').join('_').replace(/=+$/, '');",
          "}",
          "",
          "const jsonPayload = pm.collectionVariables.get('RBAC_USERINFO_JSON_EXAMPLE');",
          "const internalHeader = pm.collectionVariables.get('RBAC_GATEWAY_INTERNAL_HEADER');",
          "const internalSecret = pm.collectionVariables.get('RBAC_GATEWAY_INTERNAL_SECRET');",
          "const userinfoHeader = pm.collectionVariables.get('RBAC_GATEWAY_USERINFO_HEADER');",
          "",
          "const userinfo = base64UrlEncodeUtf8(jsonPayload);",
          "",
          "pm.request.headers.upsert({ key: internalHeader, value: internalSecret });",
          "pm.request.headers.upsert({ key: userinfoHeader, value: userinfo });"
        ]
      }
    }
